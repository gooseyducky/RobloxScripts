local function getSelectedBlock()
	local success, currentSelection = pcall(function()
		return PlayerGui.BuildGui.InventoryFrame.ScrollingFrame.BlocksFrame.Selected.Value
	end)
	
	if success and currentSelection and currentSelection ~= "" then
		return currentSelection
	end
	
	local dataFolder = LocalPlayer:FindFirstChild("Data")
	if dataFolder then
		for _, item in ipairs(dataFolder:GetChildren()) do
			if item:IsA("ValueBase") and item.Value > 0 then
				return item.Name
			end
		end
	end
	
	return "WoodBlock"
end
local function getRemoteFunction()
	local Tool = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")) 
		or LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
	
	if Tool then
		return Tool:FindFirstChild("RF")
	end
	return nil
end

local function autoPlaceBlock(RF)
	local Character = LocalPlayer.Character
	if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
	if Character.Humanoid.Health <= 0 then return end
	
	local rootPart = Character.HumanoidRootPart
	local targetCFrame = rootPart.CFrame * CFrame.new(0, 0, -DISTANCE_IN_FRONT)
	
	local currentBlock = getSelectedBlock()
	local blockDataValue = LocalPlayer.Data:FindFirstChild(currentBlock) and LocalPlayer.Data[currentBlock].Value or 1
	local targetPart = workspace:FindFirstChild(tostring(LocalPlayer.TeamColor) .. "Zone")
	local objectSpaceCFrame = targetPart and targetPart.CFrame:toObjectSpace(targetCFrame) or nil
	
	local anchorValue = false
	pcall(function()
		anchorValue = PlayerGui.BuildGui.InventoryFrame.MoreFrame.AnchorBlock.Anchor.Value
	end)
	
	pcall(function()
		RF:InvokeServer(
			currentBlock, 
			blockDataValue, 
			targetPart, 
			objectSpaceCFrame, 
			anchorValue, 
			targetCFrame, 
			false
		)
	end)
end

ToggleButton.MouseButton1Click:Connect(function()
	isLooping = not isLooping
	
	if isLooping then
		local RF = getRemoteFunction()
		if not RF then
			warn("Could not find RemoteFunction ('RF'). Make sure the tool is in your inventory!")
			isLooping = false
			return
		end
		
		local initialItem = getSelectedBlock()
		ToggleButton.Text = "Placing: " .. tostring(initialItem)
		ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		
		heartbeatConnection = RunService.Heartbeat:Connect(function()
			autoPlaceBlock(RF)
		end)
	else
		ToggleButton.Text = "Auto-Place: OFF"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
		
		if heartbeatConnection then
			heartbeatConnection:Disconnect()
			heartbeatConnection = nil
		end
	end
end)

DestroyButton.MouseButton1Click:Connect(function()
	if heartbeatConnection then
		heartbeatConnection:Disconnect()
		heartbeatConnection = nil
	end
	
	ScreenGui:Destroy()
end)

